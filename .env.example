# Resend — contact form email delivery
# 1) Create an API key:   https://resend.com/api-keys
# 2) Verify your domain:  https://resend.com/domains
RESEND_API_KEY=

# Sender shown in the "from" field. MUST use a verified domain in production.
# Example: "Andrew Sundaradhas <hello@andrewsundaradhas.dev>"
# If unset, the form falls back to Resend's test address (local/dev only).
CONTACT_FROM_EMAIL=
